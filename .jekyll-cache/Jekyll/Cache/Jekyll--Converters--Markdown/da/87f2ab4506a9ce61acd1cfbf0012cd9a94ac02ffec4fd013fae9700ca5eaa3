    <span class="k">await</span> <span class="k">this</span><span class="p">.</span><span class="nx">cacheManager</span><span class="p">.</span><span class="kd">set</span><span class="p">(</span><span class="nx">refreshToken</span><span class="p">,</span> <span class="dl">'</span><span class="s1">blacklisted</span><span class="dl">'</span><span class="p">,</span> <span class="nx">ttl</span> <span class="o">*</span> <span class="mi">1000</span><span class="p">);</span>
