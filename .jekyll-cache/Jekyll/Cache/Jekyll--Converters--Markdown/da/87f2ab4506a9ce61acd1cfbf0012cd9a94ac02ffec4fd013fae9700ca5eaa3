    <span class="na">secret</span><span class="p">:</span> <span class="k">this</span><span class="p">.</span><span class="nx">config</span><span class="p">.</span><span class="kd">get</span><span class="p">(</span><span class="dl">'</span><span class="s1">JWT_REFRESH_SECRET</span><span class="dl">'</span><span class="p">),</span>
