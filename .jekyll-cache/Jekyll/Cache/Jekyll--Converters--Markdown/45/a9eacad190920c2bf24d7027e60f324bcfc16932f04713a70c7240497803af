  <span class="nl">userId</span><span class="p">:</span> <span class="kr">string</span><span class="p">;</span>
  <span class="nl">url</span><span class="p">:</span> <span class="kr">string</span><span class="p">;</span>
  <span class="nl">type</span><span class="p">:</span> <span class="dl">'</span><span class="s1">rss</span><span class="dl">'</span> <span class="o">|</span> <span class="dl">'</span><span class="s1">web</span><span class="dl">'</span><span class="p">;</span>
<span class="p">}</span><span class="o">&gt;</span><span class="p">;</span>

<span class="k">export</span> <span class="kd">type</span> <span class="nx">ContentFoundEvent</span> <span class="o">=</span> <span class="nx">DomainEvent</span><span class="o">&lt;</span><span class="p">{</span>
  <span class="na">sourceId</span><span class="p">:</span> <span class="kr">string</span><span class="p">;</span>
  <span class="nl">title</span><span class="p">:</span> <span class="kr">string</span><span class="p">;</span>
  <span class="nl">content</span><span class="p">:</span> <span class="kr">string</span><span class="p">;</span>
  <span class="nl">url</span><span class="p">:</span> <span class="kr">string</span><span class="p">;</span>
