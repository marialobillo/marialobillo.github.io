<span class="k">export</span> <span class="kr">interface</span> <span class="nx">PaginatedResponse</span><span class="o">&lt;</span><span class="nx">T</span><span class="o">&gt;</span> <span class="p">{</span>
  <span class="na">items</span><span class="p">:</span> <span class="nx">T</span><span class="p">[];</span>
  <span class="nl">total</span><span class="p">:</span> <span class="kr">number</span><span class="p">;</span>
